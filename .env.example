# Copy this file to .env and fill in your real keys.
# Never commit the actual .env file to git — add it to .gitignore.

GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# Optional — only used if you're running Ollama locally.
# Defaults to "llama3.1" if not set.
OLLAMA_MODEL=llama3.1
